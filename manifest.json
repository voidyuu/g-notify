{
  "manifest_version": 3,
  "name": "G Notify",
  "description": "Poll Gmail and Google Calendar in the background and show Chrome notifications.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": [
    "alarms",
    "identity",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "G Notify",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
